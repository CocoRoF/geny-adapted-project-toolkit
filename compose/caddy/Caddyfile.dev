# GAPT Caddy dev config — single edge, path-based routing.
#
# Domain model:
#   gapt.hrletsgo.me/             → IDE (vite dev on host:35173)
#   gapt.hrletsgo.me/api/*        → control-plane server (compose: server:8088)
#   gapt.hrletsgo.me/health       → control-plane health
#   gapt.hrletsgo.me/preview/<slug>/* → workspace dev / prod stacks
#       Routes for individual <slug>s are injected at runtime by the
#       GAPT server via the Caddy admin API. This file only ships the
#       static handles; the admin pre-pends per-slug routes ahead of
#       the IDE fallback.
#
# Port convention: GAPT infra uses the 3xxxx prefix on the host so
# user services on 3000/5173/etc. never collide. Inside the compose
# network upstreams stay on their natural ports.
#
# Caddy joins both the compose-default network (talks to `server`)
# AND `gapt-net` (talks to per-workspace sandbox containers + per-
# prod compose stacks). The admin API on :2019 listens on all
# interfaces so the host-side GAPT server (which mutates routes) can
# reach it via the published 127.0.0.1:32019.

{
    auto_https off
    admin 0.0.0.0:2019
    # Naming the listener gives the admin API a stable mount point —
    # `/config/apps/http/servers/main/routes/...` — instead of the
    # default `srv0` which can drift if a Caddyfile reshuffle ever
    # adds a second listener.
    servers :8080 {
        name main
    }
}

:8080 {
    log {
        output stderr
        format console
    }

    encode gzip zstd

    # ───── control plane ─────
    handle /api/* {
        reverse_proxy host.docker.internal:38001
    }

    handle /health {
        reverse_proxy host.docker.internal:38001
    }

    # ───── per-workspace previews ─────
    # The admin API injects one route per exposed slug with
    # `path /preview/<slug>` + `/preview/<slug>/*`. Those routes are
    # MORE specific than `/preview/*` below, so they win when a slug
    # is registered. The `/preview/*` block here is the SAFETY NET
    # that catches any `/preview/...` URL whose slug isn't registered
    # (server restart before recovery completes, slug typo, unexpose
    # race, etc.) and returns 404 — instead of falling through to the
    # IDE catch-all and serving the GAPT SPA inside the preview
    # iframe, which produced an "IDE renders inside iframe" recursion
    # bug.
    @any_preview path /preview /preview/*
    handle @any_preview {
        respond "Preview not found. Expose a service from the IDE Service tab — or wait for the workspace to finish booting." 404
    }

    # ───── fallback: IDE / dashboard ─────
    # Vite dev runs on the host (uvicorn-style — not in compose).
    # `host.docker.internal` is Docker Desktop's host bridge; on plain
    # Linux daemons it resolves via the `extra_hosts` declaration on
    # the caddy service (see docker-compose.dev.yml).
    handle {
        reverse_proxy host.docker.internal:35173
    }
}
