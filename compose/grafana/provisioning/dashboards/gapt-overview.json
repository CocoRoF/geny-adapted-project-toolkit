{
  "uid": "gapt-overview",
  "title": "GAPT — overview",
  "schemaVersion": 39,
  "version": 1,
  "tags": ["gapt"],
  "timezone": "",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "refresh": "30s",
  "panels": [
    {
      "type": "stat",
      "title": "Active agent sessions",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "id": 1,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "gapt_sessions_active",
          "legendFormat": "active"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Sandbox containers (running)",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "id": 2,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(gapt_sandbox_count{state=\"running\"})",
          "legendFormat": "running"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Agent cost (USD) — rate per minute",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "id": 3,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(gapt_agent_cost_usd_total[1m])",
          "legendFormat": "{{project_id}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Token throughput — rate per minute",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "id": 4,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(gapt_agent_input_tokens_total[1m])",
          "legendFormat": "input — {{project_id}}"
        },
        {
          "expr": "rate(gapt_agent_output_tokens_total[1m])",
          "legendFormat": "output — {{project_id}}"
        }
      ]
    }
  ]
}
